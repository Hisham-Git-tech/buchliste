# Microblog Konfiguration - Kopiere diese Datei als .env und passe die Werte an

SECRET_KEY=dein-geheimer-schluessel-hier-aendern

# MySQL Datenbankverbindung
# Format: mysql+pymysql://BENUTZER:PASSWORT@HOST/DATENBANKNAME
DATABASE_URL=mysql+pymysql://microblog:passwort@localhost/microblog

# E-Mail (optional, für Passwort-Reset)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=1
# MAIL_USERNAME=deine@email.com
# MAIL_PASSWORD=dein-passwort
